{
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "provider_name": {
      "type": "string",
      "maxLength": 200
    },
    "connection_method": {
      "type": "string",
      "enum": [
        "",
        "MCP",
        "API"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "not_configured",
        "pending_validation",
        "validated",
        "blocked"
      ]
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "image_to_video": {
          "type": [
            "boolean",
            "string"
          ],
          "enum": [
            true,
            false,
            "unverified"
          ]
        },
        "ratios": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 20
          }
        },
        "durations_seconds": {
          "type": "array",
          "items": {
            "type": "number",
            "minimum": 1,
            "maximum": 300
          }
        },
        "submission": {
          "type": [
            "boolean",
            "string"
          ],
          "enum": [
            true,
            false,
            "unverified"
          ]
        },
        "polling": {
          "type": [
            "boolean",
            "string"
          ],
          "enum": [
            true,
            false,
            "unverified"
          ]
        },
        "download": {
          "type": [
            "boolean",
            "string"
          ],
          "enum": [
            true,
            false,
            "unverified"
          ]
        },
        "idempotency_key": {
          "type": [
            "boolean",
            "string"
          ],
          "enum": [
            true,
            false,
            "unverified"
          ]
        },
        "cost_status": {
          "type": "string",
          "enum": [
            "unknown",
            "known",
            "unavailable"
          ]
        }
      },
      "required": [
        "image_to_video",
        "ratios",
        "durations_seconds",
        "submission",
        "polling",
        "download",
        "idempotency_key",
        "cost_status"
      ],
      "additionalProperties": false
    },
    "official_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "minLength": 9,
            "maxLength": 2048
          },
          "purpose": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "checked_at": {
            "type": "string",
            "minLength": 20,
            "maxLength": 40
          }
        },
        "required": [
          "url",
          "purpose",
          "checked_at"
        ],
        "additionalProperties": false
      }
    },
    "secret_reference": {
      "type": "string",
      "maxLength": 256
    },
    "verified_at": {
      "type": "string",
      "maxLength": 40
    },
    "verification_errors": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "generation_authorized": {
      "type": "boolean",
      "const": false
    }
  },
  "required": [
    "schema_version",
    "provider_name",
    "connection_method",
    "status",
    "capabilities",
    "official_sources",
    "secret_reference",
    "verified_at",
    "verification_errors",
    "generation_authorized"
  ],
  "additionalProperties": false
}
